# Jyothi Lab Server Configs
PORT=5000
JWT_SECRET=jyothi_lab_secret_key_2026

# DB Dialect choice: sqlite (default for local setup) or postgres
DB_DIALECT=sqlite

# PostgreSQL Connection String (required if DB_DIALECT=postgres)
# DATABASE_URL=postgres://username:password@localhost:5432/jyothilab
DATABASE_URL=

# ── WhatsApp Business API (Meta Cloud API) ───────────────────────────────────
# Get these from: https://developers.facebook.com → WhatsApp → API Setup
# Leave blank to run in simulation mode (reports logged but not actually sent)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Public URL of this server (used to generate PDF download links for WhatsApp)
# For development use ngrok: ngrok http 5000 → paste the https URL here
# For production: https://your-domain.com
PUBLIC_SERVER_URL=http://localhost:5000
